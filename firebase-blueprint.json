{
  "entities": {
    "User": {
      "title": "User Profile and Settings",
      "description": "User configuration, settings, and basic profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "currency": { "type": "string" },
        "darkMode": { "type": "boolean" },
        "passcodeEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Account": {
      "title": "Account",
      "description": "Financial accounts like bank, cash, wallets.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "balance": { "type": "number" },
        "accountNo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "balance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income, expense, or transfer log.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "accountId": { "type": "string" },
        "toAccountId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "amount", "category"]
    },
    "Investment": {
      "title": "Investment",
      "description": "Portfolio assets.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "name": { "type": "string" },
        "symbol": { "type": "string" },
        "quantity": { "type": "number" },
        "buyPrice": { "type": "number" },
        "currentPrice": { "type": "number" },
        "broker": { "type": "string" }
      },
      "required": ["type", "name", "symbol", "quantity"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Core routing document for a user. Contains their settings."
    },
    "/users/{userId}/accounts/{accountId}": {
      "schema": { "$ref": "#/entities/Account" },
      "description": "User's financial accounts."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User's transactions."
    },
    "/users/{userId}/investments/{investmentId}": {
      "schema": { "$ref": "#/entities/Investment" },
      "description": "User's investments."
    }
  }
}
